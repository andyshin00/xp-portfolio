{
  "version": 2,
  "name": "winXP",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "alias": ["windowsxp.now.sh", "winxp.now.sh"]
}
